{
  "kind": "collectionType",
  "collectionName": "playlists",
  "info": {
    "singularName": "playlist",
    "pluralName": "playlists",
    "displayName": "Playlist",
    "description": "An ordered list of media items to display on a screen"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "items": {
      "type": "component",
      "repeatable": true,
      "component": "signage.playlist-item"
    },
    "screens": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::screen.screen",
      "mappedBy": "playlist"
    }
  }
}
