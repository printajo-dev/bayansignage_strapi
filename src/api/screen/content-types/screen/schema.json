{
  "kind": "collectionType",
  "collectionName": "screens",
  "info": {
    "singularName": "screen",
    "pluralName": "screens",
    "displayName": "Screen",
    "description": "A physical signage display that plays an assigned playlist"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "location": {
      "type": "string"
    },
    "pairingCode": {
      "type": "string",
      "unique": true
    },
    "lastSeenAt": {
      "type": "datetime"
    },
    "playlist": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::playlist.playlist",
      "inversedBy": "screens"
    }
  }
}
